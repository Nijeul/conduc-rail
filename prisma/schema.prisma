generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role         String   @default("user")
  logoSociete    String?
  nomSociete     String?
  adresseSociete String?
  telSociete     String?
  faxSociete     String?
  certifications String?
  createdAt      DateTime @default(now())
  projets      ProjetMember[]
  rapports  RapportJournalier[] @relation("redacteur")
}

model Projet {
  id           String   @id @default(cuid())
  name         String
  description  String?
  createdAt    DateTime @default(now())
  moaNom          String?
  moaPrenom       String?
  moaAdresse      String?
  numeroAffaire   String?
  numeroCommande  String?
  numeroOTP       String?
  adresseChantier String?
  dateDebut       DateTime?
  dateFin         DateTime?
  updatedAt       DateTime @updatedAt
  members         ProjetMember[]
  tableaux        TableauService[]
  lignesDE        LigneDE[]
  rapports        RapportJournalier[]
  soudures        SoudureAluminothermique[]
  compositions    CompositionTTx[]
  evenements      EvenementChantier[]
  categories      CategorieEvenement[]
  courriers        CourrierChantier[]
  lignesFicheEcart LigneFicheEcart[]
  lignesARFManuelles LigneARFManuelle[]
  ocps              OCP[]
  matrices          MatriceDecisionnelle[]
}

model ProjetMember {
  id       String @id @default(cuid())
  userId   String
  projetId String
  role     String @default("member")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  projet   Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
  @@unique([userId, projetId])
}

model Personnel {
  id         String   @id @default(cuid())
  nom        String
  prenom     String
  poste      String
  telephone  String?
  entreprise String?
  createdAt  DateTime @default(now())
}

model TableauService {
  id         String   @id @default(cuid())
  projetId   String
  titre      String
  entreprise String?
  semaine    Int
  annee      Int
  colonnes   Json
  lignes     Json
  cellules   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  projet     Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  planningLinks PlanningPersonnelLink[]
  @@index([projetId])
}

model LigneDE {
  id           String   @id @default(cuid())
  projetId     String
  code         String
  designation  String
  unite        String
  quantite     Float
  prixUnitaire Float
  ordre        Int      @default(0)
  createdAt    DateTime @default(now())
  projet       Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  avancements  LigneAvancement[]
  @@index([projetId])
}

model RapportJournalier {
  id               String    @id @default(cuid())
  projetId         String
  date             DateTime
  nomChantier      String?
  titre            String?
  posteNuit        Boolean   @default(true)
  heureDebutPrevue String?
  heureFinPrevue   String?
  heureDebut       String?
  heureFin         String?
  heureRestituee   String?
  production       String?
  commentaire      String?
  redacteurId      String?
  dateRedaction    DateTime?
  valide           Boolean   @default(false)
  travaux          Json      @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  projet           Projet    @relation(fields: [projetId], references: [id], onDelete: Cascade)
  redacteur        User?     @relation("redacteur", fields: [redacteurId], references: [id])
  avancements      LigneAvancement[]
  @@index([projetId])
}

model SoudureAluminothermique {
  id            String    @id @default(cuid())
  projetId      String
  ordre         Int       @default(0)
  zoneTravaux   String?
  date          DateTime?
  poincon       String?
  pk            String?
  voie          String?
  fileGD        String?
  lacune        String?
  profilRail    String?
  nuanceAcier   String?
  e1            String?
  e2            String?
  meulageProfil String?
  creuxZone     String?
  tracePointu   String?
  traceCreux    String?
  traceMeulage  String?
  observations  String?
  reception     String?
  raisonHS      String?
  couleurLigne  String?
  createdAt     DateTime  @default(now())
  projet        Projet    @relation(fields: [projetId], references: [id], onDelete: Cascade)
  @@index([projetId])
}

model MaterielTTx {
  id                String   @id @default(cuid())
  type              String
  designation       String
  imageUrl          String?
  nbEssieux         Float?
  poidsEntrant      Float?
  poidsSortant      Float?
  longueur          Float?
  capTraction       Float?
  capEssieuxFreines Float?
  commentaires      String?
  estSysteme        Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model CategorieEvenement {
  id            String   @id @default(cuid())
  projetId      String
  nom           String
  couleurBg     String   @default("#F0F0F0")
  couleurBorder String   @default("#B5ABA1")
  couleurText   String   @default("#5A5A5A")
  couleurPoint  String   @default("#B5ABA1")
  estSysteme    Boolean  @default(false)
  createdAt     DateTime @default(now())
  projet        Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  evenements    EvenementChantier[]
  @@unique([projetId, nom])
}

model EvenementChantier {
  id             String    @id @default(cuid())
  projetId       String
  date           DateTime
  titre          String
  description    String?
  categorie      String
  categorieId    String?
  afficherFrise  Boolean   @default(true)
  source         String?
  courrierId     String?
  fichiers       FichierEvenement[]
  createdAt      DateTime  @default(now())
  projet         Projet    @relation(fields: [projetId], references: [id], onDelete: Cascade)
  courrier       CourrierChantier? @relation(fields: [courrierId], references: [id])
  categorieRef   CategorieEvenement? @relation(fields: [categorieId], references: [id])
  @@index([projetId])
  @@index([categorieId])
}

model FichierEvenement {
  id          String   @id @default(cuid())
  evenementId String
  nom         String
  type        String
  contenu     String
  taille      Int
  createdAt   DateTime @default(now())
  evenement   EvenementChantier @relation(fields: [evenementId], references: [id], onDelete: Cascade)
}

model CourrierChantier {
  id           String    @id @default(cuid())
  projetId     String
  reference    String
  objet        String
  type         String
  dateEnvoi    DateTime?
  destinataire String?
  expediteur   String?
  corps        String    @default("")
  statut       String    @default("brouillon")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projet       Projet    @relation(fields: [projetId], references: [id], onDelete: Cascade)
  evenements   EvenementChantier[]
  @@index([projetId])
}

model CompositionTTx {
  id        String    @id @default(cuid())
  projetId  String
  titre     String?
  date      DateTime?
  sens      String    @default("Paris → Province")
  vehicules Json      @default("[]")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projet    Projet    @relation(fields: [projetId], references: [id], onDelete: Cascade)
  planningLinks PlanningTractionLink[]
  @@index([projetId])
}

model LigneFicheEcart {
  id               String   @id @default(cuid())
  projetId         String
  evenementId      String?
  etude            String   @default("")
  prevuDCE         String   @default("")
  phaseTransitoire String   @default("")
  exe              String   @default("")
  impacts          String   @default("")
  delaisImpactes   String   @default("")
  coutImpactes     String   @default("")
  ordre            Int      @default(0)
  chapitre         String   @default("")
  estChapitre      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  projet           Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  @@index([projetId])
}

model LigneARFManuelle {
  id               String   @id @default(cuid())
  projetId         String
  date             DateTime
  posteNuit        Boolean  @default(true)
  heureDebutPrevue String?
  heureFinPrevue   String?
  heureDebut       String?
  heureFin         String?
  heureRestituee   String?
  commentaire      String?
  ordre            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  projet           Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  @@index([projetId])
}

model LigneAvancement {
  id               String            @id @default(cuid())
  ligneDEId        String
  rapportId        String
  quantiteRealisee Float
  ligneDE          LigneDE           @relation(fields: [ligneDEId], references: [id], onDelete: Cascade)
  rapport          RapportJournalier @relation(fields: [rapportId], references: [id], onDelete: Cascade)
  @@unique([ligneDEId, rapportId])
}

// ──────────────────────────────────────────────
// Module A — Planning Minuté (OCP)
// ──────────────────────────────────────────────

model OCP {
  id                String   @id @default(cuid())
  projetId          String
  nom               String
  dateDebut         DateTime
  dateFin           DateTime
  version           String   @default("BASE")
  indice            String?
  dfvTotalMinutes   Int      @default(0)
  statut            String   @default("brouillon")
  ocpBaseId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  projet            Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  ocpBase           OCP?     @relation("VarianteDeBase", fields: [ocpBaseId], references: [id])
  variantes         OCP[]    @relation("VarianteDeBase")
  chantiersElementaires ChantierElementaire[]
  personnelLinks        PlanningPersonnelLink[]
  tractionLinks         PlanningTractionLink[]
  @@index([projetId])
}

model ChantierElementaire {
  id                    String   @id @default(cuid())
  ocpId                 String
  libelle               String
  categorie             String?
  couleur               String?
  dureePlanifieeMinutes Int      @default(0)
  ordreAffichage        Int      @default(0)
  estGroupe             Boolean  @default(false)
  createdAt             DateTime @default(now())
  ocp                   OCP      @relation(fields: [ocpId], references: [id], onDelete: Cascade)
  creneaux              CreneauActivite[]
  @@index([ocpId])
}

model CreneauActivite {
  id                     String   @id @default(cuid())
  chantierElementaireId  String
  debut                  DateTime
  fin                    DateTime
  effectif               Int      @default(1)
  statut                 String   @default("planifie")
  createdAt              DateTime @default(now())
  chantierElementaire    ChantierElementaire @relation(fields: [chantierElementaireId], references: [id], onDelete: Cascade)
  @@index([chantierElementaireId])
}

model PlanningPersonnelLink {
  id               String         @id @default(cuid())
  ocpId            String
  tableauServiceId String
  debut            DateTime
  fin              DateTime
  createdAt        DateTime       @default(now())
  ocp              OCP            @relation(fields: [ocpId], references: [id], onDelete: Cascade)
  tableauService   TableauService @relation(fields: [tableauServiceId], references: [id], onDelete: Cascade)
  @@index([ocpId])
}

model PlanningTractionLink {
  id               String         @id @default(cuid())
  ocpId            String
  compositionId    String
  heureArrivee     DateTime
  heureDepart      DateTime
  label            String?
  createdAt        DateTime       @default(now())
  ocp              OCP            @relation(fields: [ocpId], references: [id], onDelete: Cascade)
  composition      CompositionTTx @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  @@index([ocpId])
}

// ──────────────────────────────────────────────
// Module B — Matrice Décisionnelle
// ──────────────────────────────────────────────

model MatriceDecisionnelle {
  id              String   @id @default(cuid())
  projetId        String
  titre           String
  acheteur        String?
  site            String?
  familleAchats   String?
  budgetTheorique Float?
  devise          String   @default("EUR")
  seuilGo         Float    @default(60)
  statut          String   @default("brouillon")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  projet          Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  fournisseurs    FournisseurCandidat[]
  criteres        Critere[]
  @@index([projetId])
}

model FournisseurCandidat {
  id              String    @id @default(cuid())
  matriceId       String
  nom             String
  rang            Int       @default(1)
  refOffre        String?
  dateOffre       DateTime?
  paysFabrication String?
  incoterm        String?
  montantOffre    Float?
  decision        String    @default("en_attente")
  couleurDecision String    @default("jaune")
  createdAt       DateTime  @default(now())
  matrice         MatriceDecisionnelle @relation(fields: [matriceId], references: [id], onDelete: Cascade)
  notations       NotationCritere[]
}

model Critere {
  id              String   @id @default(cuid())
  matriceId       String
  famille         String
  libelle         String
  coefficient     Float    @default(1)
  ordreAffichage  Int      @default(0)
  type            String   @default("note_1_3")
  createdAt       DateTime @default(now())
  matrice         MatriceDecisionnelle @relation(fields: [matriceId], references: [id], onDelete: Cascade)
  notations       NotationCritere[]
}

model NotationCritere {
  id                          String   @id @default(cuid())
  critereId                   String
  fournisseurId               String
  valeurTexte                 String?
  note                        Int?
  valeurBool                  Boolean?
  commentaire                 String?
  estNonConformiteMajeure     Boolean  @default(false)
  estNonConformiteNegociable  Boolean  @default(false)
  createdAt                   DateTime @default(now())
  critere                     Critere  @relation(fields: [critereId], references: [id], onDelete: Cascade)
  fournisseur                 FournisseurCandidat @relation(fields: [fournisseurId], references: [id], onDelete: Cascade)
  @@unique([critereId, fournisseurId])
}
